:root {
}

.button {
    width: 45%;
    height: 45%;
    min-width: 0%;
    min-height: 0%;
    max-width: 50%;
    max-height: 50%;
    aspect-ratio: auto;
    border-top-left-radius: 17px;
    border-top-right-radius: 17px;
    border-bottom-right-radius: 17px;
    border-bottom-left-radius: 17px;
}

.text {
    -unity-font-style: bold;
    -unity-text-outline-color: rgb(255, 255, 255);
    color: rgb(255, 255, 255);
}
